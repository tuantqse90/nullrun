# Copy to .env for local overrides. Defaults in src/config.rs match docker-compose.yml.
BIND_ADDR=0.0.0.0:8080
# Ports 5433/6380 to avoid the local Postgres/Redis already on this machine (see docker-compose.yml)
DATABASE_URL=postgres://nullshift:nullshift@localhost:5433/nullshift
REDIS_URL=redis://localhost:6380
RUST_LOG=info,tower_http=debug
JWT_SECRET=change-me-in-any-shared-environment
# dev = attestation accepted unverified (no iOS build yet); apple = full App Attest (required for prod)
ATTEST_MODE=dev
